#!/bin/bash
# (c) Stefan Countryman 2024

__emacsd_procs () {
    printf %s "${procs}"
}

__emacsd_procs_found () {
    [[ $(__emacsd_procs | wc -c) -gt 0 ]] && return 0 || return 1
}

emacsd () {
    local HELP='Start up the emacs daemon; `l` to list existing, `k` to kill existing'
    local MIN_NODE_VERSION=22
    local l=0
    local k=0
    local l_or_k
    local procs

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            l|li|lis|list)
                l=1
                shift
                ;;
            k|ki|kil|kill)
                k=1
                shift
                ;;
            *)
                echo "${HELP}"
                return 1
                ;;
        esac
    done

    # Handle listing or killing. `-i` so the `Emacs` binary name used when
    # launched via Emacs.app/EmacsMac.app also matches. `-daemon` (single
    # hyphen) catches both `--daemon` (the short-lived parent) and
    # `--bg-daemon=<fds>` (the actual detached daemon in Emacs 27+).
    l_or_k=$((l + k))
    if [[ ${l_or_k} -gt 0 ]]; then
        procs="$(ps -ax | grep -iE 'emacs.*-daemon' | sed '/grep/d')"
    fi
    if [[ ${l} -eq 1 ]]; then
        __emacsd_procs_found && (__emacsd_procs; echo)
    fi
    if [[ ${k} -eq 1 ]]; then
        __emacsd_procs_found \
            && (
                __emacsd_procs | sed 's/^ *//' | cut -d ' ' -f 1 | xargs kill
                printf >&2 'Killed:\n%s\n' "${procs}"
            ) \
            || echo >&2 'No emacs daemon procs found.'
    fi
    if [[ ${l_or_k} -gt 0 ]]; then
        __emacsd_procs_found && return 0 || return 1
    fi

    # Start the daemon
    (
        # Use Anaconda/Miniconda for CMake LSP support.
        # Candidate install roots, in priority order (new macOS, new Linux,
        # old macOS/Linux user install, old user miniconda).
        local conda_base
        for conda_base in \
            /opt/miniconda3 \
            /opt/anaconda3 \
            "$HOME/anaconda3" \
            "$HOME/miniconda3" \
        ; do
            if [ -f "${conda_base}/bin/activate" ]; then
                source "${conda_base}/bin/activate"
                break
            fi
        done
        if ! type conda >/dev/null 2>&1; then
            echo >&2 "WARNING: no conda install found; LSP may not work"
        fi
        conda activate emacs
        # Make sure to use proper node if available (for LSP)
        if (type node >/dev/null 2>&1); then
            local node_version="$(node --version | cut -d . -f 1 | tr -dc '[0-9]')"
            if [[ ${node_version} -lt ${MIN_NODE_VERSION} ]]; then
                echo >&2 "Detected bad node version ${node_version}..."
                if (type nvm >/dev/null 2>&1); then
                    echo >&2 "Using NVM to set node version to ${MIN_NODE_VERSION}"
                    nvm use "${MIN_NODE_VERSION}"
                else
                    echo >&2 "WARNING: node version ${node_version} is too old for LSP and no \`nvm\` detected"
                fi
            else
                echo >&2 "Found valid node version ${node_version} for LSP"
            fi
        else
            echo >&2 'WARNING: `node` command not found, LSP will not work'
        fi
        if [[ "$OSTYPE" == darwin* ]]; then
            # On macOS, launch Emacs.app as a regular GUI process rather
            # than in --daemon mode. `open -a Emacs --args --daemon`
            # hangs on emacs-mac because its Cocoa .app init path
            # doesn't cooperate with daemon mode. Instead, Emacs.app
            # runs as an ordinary app and config.el calls `server-start`
            # so `emc` can connect via the Unix socket; `emc -c`
            # surfaces the hidden app window via `open -a Emacs`.
            if pgrep -f '\.app/Contents/MacOS/Emacs' >/dev/null 2>&1; then
                echo >&2 'Emacs.app is already running; nothing to do.'
            else
                # Refresh Doom's env snapshot (`$DOOMDIR/env`) from this
                # activated subshell so Emacs.app picks up conda/nvm
                # PATH — `open -a` launches via launchd and does NOT
                # inherit this shell's environment.
                if type doom >/dev/null 2>&1; then
                    echo >&2 'Refreshing Doom env snapshot...'
                    doom env >/dev/null
                else
                    echo >&2 'WARNING: `doom` not on PATH; skipping env snapshot refresh'
                fi
                # `-g` = don't bring to foreground; `-j` = launch hidden
                # (like Cmd-H on first paint).
                echo >&2 'Launching Emacs.app hidden...'
                open -gja Emacs 2>/dev/null || open -gja EmacsMac
            fi
        else
            echo >&2 'Starting emacs daemon...'
            emacs --daemon
        fi
    )
}
